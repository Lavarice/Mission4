{% extends 'base.html.twig' %}

{% block body %}
<!-- page start-->
<div class="col-sm-8">
    <section class="panel">
        <div class="chat-room-head">
            <h3><i class="fa fa-angle-right"></i> Gérer les genres</h3>
        </div>
        <div class="panel-body">

    <table class="table-striped table-advance table-hover">
        <thead>
            <tr class="tableau-entete">
                <th><i class="fa fa-bullhorn"></i> Identif</th>
                <th><i class="fa fa-bookmark"></i> Libellé</th> 
            </tr>
        </thead>
        <tbody>
        {% for plateforme in plateformes %}
            <tr>
                <td>{{ plateforme.id }}</td>
                <td>{{ plateforme.libPlateforme }}</td>
                <td>
                    <a href="{{ path('app_plateformes_show', {'id': plateforme.id})}}"><button
class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></button></a>
                    <a href="{{ path('app_plateformes_edit', {'id': plateforme.id})}}"><button
class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Aucun genre enregistré en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_plateformes_new') }}"><button class="btn btn-primary btnxs"><i class="fa fa-plus"></i></button></a>
</div><!-- fin div panel-body-->
</section><!-- fin section tournois-->
</div><!--fin div col-sm-8-->
{% endblock %}
