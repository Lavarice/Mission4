{% extends 'base.html.twig' %}

{% block title %}Statistiques des Tournois{% endblock %}

{% block body %}
<div class="col-sm-8">
    <section class="panel">
        <div class="chat-room-head">
            <h3>
                <i class="fa fa-angle-right"></i> Statistiques des tournois
            </h3>
        </div>
        <div class="panel-body">
            <table class="table table-striped table-advance table-hover">
                <thead>
                    <tr class="tableau-entete">
                        <th><i class="fa fa-gamepad"></i> Tournoi</th>
                        <th><i class="fa fa-list"></i> Catégorie</th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in stats %}
                        <tr>
                            <td>{{ t.libelle }}</td>
                            <td>{{ t.categorie }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div><!-- fin div panel-body-->
    </section><!-- fin section tournois-->
</div><!--fin div col-sm-8-->
{% endblock %}
